# Production secrets for docker-compose.prod.yml.
#   cp .env.prod.example .env.prod   # then edit — NEVER commit .env.prod
#
# Usage:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# Postgres password (also used by the backend datasource).
POSTGRES_PASSWORD=change-me

# Base64-encoded HMAC secret for JWT signing (>= 256 bits). Generate with:
#   openssl rand -base64 48
HMS_JWT_SECRET=change-me-generate-with-openssl-rand-base64-48

# Initial password for the bootstrap "admin" user. Only consumed on the very
# first start while the users table is empty; change the password from inside
# the application immediately after first login.
HMS_ADMIN_INITIAL_PASSWORD=change-me
